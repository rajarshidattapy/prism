{
  "version": "0.1",
  "type": "container",
  "meta": {
    "trigger": "manual",
    "description": "MiroFish OASIS Matrix — 1M-agent sentiment simulation for PRISM market underwriting"
  },
  "ops": [
    {
      "type": "container/run",
      "id": "mirofish-matrix",
      "args": {
        "image": "ghcr.io/team-kaizen/prism-simulation:latest",
        "cmd": [
          "python",
          "simulation/scripts/run_matrix.py",
          "--question", { "$$nosana$$": "input", "name": "MARKET_QUESTION" },
          "--context",  { "$$nosana$$": "input", "name": "MARKET_CONTEXT" },
          "--n_agents", "1000000",
          "--noise", "0.12"
        ],
        "env": [
          { "PYTHONUNBUFFERED": "1" }
        ],
        "gpu": true,
        "gpu_count": 1,
        "memory": "16Gi"
      }
    },
    {
      "type": "container/run",
      "id": "generate-attestation",
      "args": {
        "image": "ghcr.io/team-kaizen/prism-simulation:latest",
        "cmd": ["python", "simulation/scripts/generate_attestation.py"],
        "env": [
          { "SOLANA_RPC_URL": { "$$nosana$$": "secret", "name": "SOLANA_RPC_URL" } },
          { "SOLANA_PRIVATE_KEY": { "$$nosana$$": "secret", "name": "SOLANA_PRIVATE_KEY" } },
          { "PRISM_PROGRAM_ID": { "$$nosana$$": "secret", "name": "PRISM_PROGRAM_ID" } },
          { "MARKET_PDA": { "$$nosana$$": "input", "name": "MARKET_PDA" } }
        ],
        "gpu": false,
        "memory": "512Mi"
      },
      "needs": ["mirofish-matrix"]
    }
  ],
  "resources": {
    "cpu": "8",
    "memory": "16Gi",
    "storage": "10Gi",
    "gpu": "1"
  },
  "timeout": 3600,
  "output": {
    "artifact": "simulation/outputs/"
  }
}
